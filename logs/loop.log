import queue
import time

# Function to read prompts from the file and enqueue them
def load_prompts(file_path):
    prompt_queue = queue.Queue()
    
    with open(file_path, 'r') as file:
        for line in file:
            # Strip any leading/trailing whitespace and add to the queue
            prompt_queue.put(line.strip())
    
    return prompt_queue

# Function to process each prompt from the queue
def process_prompts(prompt_queue):
    while not prompt_queue.empty():
        prompt = prompt_queue.get()
        print(f"Processing prompt: {prompt}")
        
        # Simulate some processing time
        time.sleep(1)
        
        # Mark the task as done
        prompt_queue.task_done()

# Main function to run the queueing system
def main():
    file_path = '/home/jericho/zion/docs/research/01_CODES.txt'
    
    # Load prompts into the queue
    prompt_queue = load_prompts(file_path)
    
    print(f"Loaded {prompt_queue.qsize()} prompts from {file_path}")
    
    # Process each prompt in the queue
    process_prompts(prompt_queue)
    
    print("All prompts have been processed.")

if __name__ == "__main__":
    main()
```

