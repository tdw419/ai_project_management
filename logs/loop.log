# Install watchdog if not already installed: pip install watchdog

from watchdog.observers import Observer
from watchdog.events import FileSystemEventHandler

class CodeFileHandler(FileSystemEventHandler):
    def on_modified(self, event):
        if event.src_path.endswith('.code'):
            print(f"Code file modified: {event.src_path}")
            self.process_file(event.src_path)

    def process_file(self, file_path):
        # Implement parsing and other tasks here
        pass

if __name__ == "__main__":
    observer = Observer()
    observer.schedule(CodeFileHandler(), path='~/zion/projects/', recursive=False)
    observer.start()

    try:
        while True:
            time.sleep(1)
    except KeyboardInterrupt:
        observer.stop()
    observer.join()
```

### 2. Parsing Code Files

Assuming your code files are simple and each line contains a coordinate:

```python
def parse_code_file(file_path):
    coordinates = []
    with open(file_path, 'r') as file:
        for line in file:
            coord = tuple(map(int, line.strip().split(',')))
            coordinates.append(coord)
    return coordinates
```

