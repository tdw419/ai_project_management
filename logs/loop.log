def convert_to_rts_png(data, filename):
    # Assuming data is a 2D list representing the grid
    width = len(data[0])
    height = len(data)
    
    # Create an image with white background
    img = Image.new('RGB', (width * 16, height * 16), color = 'white')
    d = ImageDraw.Draw(img)
    
    # Draw the grid
    for x in range(width + 1):
        d.line([(x * 16, 0), (x * 16, height * 16)], fill=0)
    for y in range(height + 1):
        d.line([(0, y * 16), (width * 16, y * 16)], fill=0)
    
    # Fill the grid cells with black based on your data
    for x in range(width):
        for y in range(height):
            if data[y][x] == '1':  # Example condition: cell contains a '1'
                d.rectangle([(x * 16, y * 16), ((x + 1) * 16, (y + 1) * 16)], fill=0)
    
    # Save the image
    img.save(filename)

